# Bot token from the Discord Developer Portal (https://discord.com/developers/applications).
# Keep this secret — never commit your real .env file.
DISCORD_TOKEN=

# Optional: log verbosity — one of debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Optional Spotify credentials (for resolving full playlists and albums via /play).
# Get them free from https://developer.spotify.com/dashboard (create an app).
# Without these, Spotify playlist/album links will fall back to a single track (album name search).
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# ── Website API (Phase 2 / 3a) ────────────────────────────────────────────────
# Serves public stats + Discord OAuth admin endpoints for the marketing site.
# Defaults: enabled on 0.0.0.0:3848. Set API_ENABLED=false to turn off.
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=3848

# Comma-separated browser origins allowed by CORS (credentials for admin routes).
# Include every origin you serve the website from (npx serve, Live Server, etc.).
# Include "null" if you open the site as a local file:// page during development.
# Localhost any port is also allowed automatically in the API CORS helper.
WEBSITE_ORIGIN=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080,null

# Discord OAuth2 (Application → OAuth2). client_id comes from config.json discord.clientId.
# Add the redirect URL below to the Discord app's OAuth2 redirect list.
DISCORD_CLIENT_SECRET=
SESSION_SECRET=change-me-to-long-random
OAUTH_REDIRECT_URI=http://127.0.0.1:3848/api/auth/callback
