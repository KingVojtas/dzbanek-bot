# Bot token from the Discord Developer Portal (https://discord.com/developers/applications).
# Keep this secret — never commit your real .env file.
DISCORD_TOKEN=

# Optional: log verbosity — one of debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Optional Spotify credentials (for resolving full playlists and albums via /play).
# Get them free from https://developer.spotify.com/dashboard (create an app).
# Without these, Spotify playlist/album links will fall back to a single track (album name search).
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# ── YouTube extraction (Railway / cloud) ──────────────────────────────────────
# Cookies alone often die after a few plays on datacenter IPs. Prefer a residential proxy.
# YTDLP_PROXY=http://user:pass@host:port
# YTDLP_PROXY=socks5://user:pass@host:port
# Also accepted: HTTPS_PROXY / HTTP_PROXY / ALL_PROXY
#
# Optional Netscape cookies (base64 of cookies.txt) — helps with age-gate / some clients.
# YTDLP_COOKIES_BASE64=
# YTDLP_IGNORE_COOKIES=1

# ── Website API ───────────────────────────────────────────────────────────────
# Serves public stats + Discord OAuth admin (+ optional static site files).
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=3848

# Public URL of this API / site in production (no trailing slash).
# Fly.io example: https://dzbanek-bot.fly.dev
# PUBLIC_BASE_URL=https://dzbanek-bot.fly.dev

# Comma-separated CORS origins for browser admin + stats (credentials).
WEBSITE_ORIGIN=https://dzbanek-bot.vojtas.io,https://kingvojtas.github.io,https://dzbanek-bot.fly.dev,http://127.0.0.1:3848,http://localhost:3848,http://127.0.0.1:3000,http://localhost:3000,null

# After OAuth, send users back to the public marketing site (GitHub Pages)
# WEBSITE_PRIMARY_ORIGIN=https://kingvojtas.github.io

# Discord OAuth2 (Application → OAuth2). client_id comes from config.json discord.clientId.
# Redirect must match Discord Developer Portal exactly.
DISCORD_CLIENT_SECRET=
SESSION_SECRET=change-me-to-long-random
# Local:
OAUTH_REDIRECT_URI=http://127.0.0.1:3848/api/auth/callback
# Production (Fly):
# OAUTH_REDIRECT_URI=https://dzbanek-bot.fly.dev/api/auth/callback
